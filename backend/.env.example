PORT=3001
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=telega
# Альтернатива отдельным DB_* переменным:
DATABASE_URL=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
BLOCKED_USER_MESSAGE=Ваш аккаунт заблокирован. Для разблокировки свяжитесь с поддержкой.

# Test payment mode. Keep test credentials here; do not commit real production keys.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:5173/checkout/success

# Публичный адрес приложения, например https://telega-shop.onrender.com
PUBLIC_URL=http://localhost:5173

# VK bot (обязательно VK_GROUP_ID для ссылки привязки в профиле)
VK_BOT_TOKEN=
VK_GROUP_ID=123456789
VK_PUBLIC_SCREEN_NAME=
VK_LONG_POLL_ENABLED=true
VK_ADMIN_USER_IDS=
